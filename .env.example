# FamilyBot — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Required: Parent phones (E.164, e.g. +12125551234) ──────────────────────
AVIV_PHONE=+12125550001
LIAT_PHONE=+12125550002

# ── Required: Display names (used in calendar labels) ────────────────────────
PARENT1_NAME=Parent 1
PARENT2_NAME=Parent 2

# ── Required: Master WhatsApp group ──────────────────────────────────────────
# Exact group name (used as fallback) and JID (preferred — see README for how to find it)
MASTER_GROUP_NAME=Family Tasks
MASTER_GROUP_JID=120363000000000000@g.us

# ── Required: Google Calendar IDs ────────────────────────────────────────────
AVIV_CALENDAR_ID=parent1@gmail.com
LIAT_CALENDAR_ID=parent2@gmail.com
LIAT_WORK_CALENDAR_ID=parent2@yourworkdomain.com   # optional, leave empty if not needed

# ── Required: Google OAuth token paths (generated on first auth, then gitignored) ──
GOOGLE_CREDENTIALS_PATH=./credentials.json
AVIV_TOKEN_PATH=./token-aviv.json
LIAT_TOKEN_PATH=./token-liat.json

# ── Required: Anthropic API key ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Required: Timezone ────────────────────────────────────────────────────────
TIMEZONE=Asia/Jerusalem

# ── Optional: Chromium path (required on headless VPS — see README) ──────────
# Ubuntu/Debian: sudo apt install chromium-browser
# Then set: CHROMIUM_PATH=/usr/bin/chromium-browser
CHROMIUM_PATH=

# ── Optional: Bot identity ────────────────────────────────────────────────────
BOT_NAME=FamilyBot
BOT_NAME_ALT=familybot

# ── Optional: Daily LLM token budget (across all API calls) ──────────────────
TOKEN_LIMIT_DAILY=200000

# ── Optional: S3 backup bucket (leave empty to disable cloud backup) ─────────
# Grant your server's IAM role s3:PutObject on this bucket
S3_BACKUP_BUCKET=

# ── Feature flags (1=on, 0=off) ───────────────────────────────────────────────
FEAT_CONV_HISTORY=1
FEAT_MEMBER_RES=1
FEAT_CONFIRM=1
FEAT_CLARIFY=1
